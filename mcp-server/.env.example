# Wordz MCP server environment variables.
# Copy this file to `mcp-server/.env` and fill in credentials for the Wordz
# API player you want this server to control.
#
# Both values can also be supplied via a credentials file (see
# mcp-server/README.md); environment variables take precedence.

WORDZ_API_URL=https://your-project-ref.supabase.co/functions/v1/game-api
WORDZ_API_KEY=wz_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
