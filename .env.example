# Wordz frontend environment variables.
# Copy this file to `.env` and fill in the values from your Supabase project
# (Dashboard → Project Settings → API).
#
# Both variables are required. They are the *publishable* key and project URL,
# which are safe to ship in browser code — real security is enforced by Row
# Level Security policies on every table. Never put the service role key or
# DATABASE_URL here; those belong in `.env.local` (gitignored) or in the
# Supabase Edge Function secret store.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
